{
  "name": "@kchat/mls-napi",
  "version": "0.2.0",
  "description": "Node.js bindings for KChat MLS SDK using NAPI-RS",
  "license": "MIT OR Apache-2.0",
  "author": "KChat Authors",
  "homepage": "https://kchat.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/KChatGlobal/kchat-rust-sdk.git",
    "directory": "crates/kchat-mls-napi"
  },
  "bugs": {
    "url": "https://github.com/KChatGlobal/kchat-rust-sdk/issues"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "require": "./index.js",
      "import": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "npm/**/*",
    "*.node",
    "README.md"
  ],
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "napi": {
    "binaryName": "kchat-mls-napi",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">= 10"
  },
  "packageManager": "yarn@4.9.1",
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "version": "napi version",
    "bump": "node scripts/version.js",
    "#prepublishOnly": "napi build --platform --release",
    "install": "node scripts/install.js"
  },
  "keywords": [
    "napi",
    "napi-rs",
    "mls",
    "kchat",
    "native",
    "addon"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.2.0",
    "argparse": "^2.0.1",
    "chalk": "^5.6.2",
    "typescript": "^5.9.2"
  }
}
